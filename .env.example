# Postgres
POSTGRES_USER=stream_pilot
POSTGRES_PASSWORD=stream_pilot_password
POSTGRES_DB=stream_pilot
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# API
API_PORT=3001
DATABASE_URL=postgresql://stream_pilot:stream_pilot_password@postgres:5432/stream_pilot
JWT_SECRET=stream_pilot_jwt_secret
JWT_EXPIRES_IN=7d

# Rate limiting (API)
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
THROTTLE_AUTH_TTL_MS=60000
THROTTLE_AUTH_LIMIT=10

# App
APP_PORT=3000
NEXT_PUBLIC_API_URL=/api
API_INTERNAL_URL=http://api:3001

# Web Push (VAPID)
VAPID_PUBLIC_KEY=vapid_public_key
VAPID_PRIVATE_KEY=vapid_private_key
VAPID_SUBJECT=mailto:vapid_subject@example.com
