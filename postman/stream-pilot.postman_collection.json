                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Returns dashboard stats', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('productions');",
                  "    pm.expect(json.productions).to.have.property('total');",
                  "    pm.expect(json.productions).to.have.property('byStatus');",
                  "    pm.expect(json).to.have.property('crew');",
                  "    pm.expect(json.crew).to.have.property('unassigned');",
                  "    pm.expect(json.crew).to.have.property('topBooked');",
                  "    pm.expect(json).to.have.property('equipment');",
                  "    pm.expect(json.equipment).to.have.property('unassigned');",
                  "    pm.expect(json.equipment).to.have.property('topBooked');",
